<a href="<%= url %>" target="_blank" rel="noopener"
   class="group block bg-white/[2.5%] border border-white/10 rounded-lg px-4 py-4 no-underline transition-all hover:bg-white/5 hover:border-green-400/20">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-1.5 flex-wrap">
      <%= repo_name %>
      <%= role_badge %>
    </div>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2" class="shrink-0 stroke-white/20 group-hover:stroke-green-400 transition-colors"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
  </div>
  <p class="font-sans text-xs text-slate-400 leading-relaxed mt-0 mb-2.5"><%= description %></p>
  <div class="flex gap-1.5 flex-wrap">
    <% tags.each do |tag| %>
      <%= tag_pill(tag) %>
    <% end %>
  </div>
</a>
